# Swarmcore – environment variables for HTTPS / TLS setup
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Domain variant (Let's Encrypt) ────────────────────────────────────────────
# Public DNS names that point to this server.
TRACKER_DOMAIN=tracker.example.com
ADMIN_DOMAIN=admin.example.com

# Email used for Let's Encrypt account registration and expiry notifications.
CERTBOT_EMAIL=admin@example.com

# ── IP variant (self-signed certificate) ──────────────────────────────────────
# Public IP of this server. Used by generate-ip-cert.sh.
# Leave blank to let the script auto-detect via api.ipify.org.
# SERVER_IP=1.2.3.4

# Optionally use different IPs per service (defaults to SERVER_IP):
# TRACKER_IP=1.2.3.4
# ADMIN_IP=1.2.3.4
