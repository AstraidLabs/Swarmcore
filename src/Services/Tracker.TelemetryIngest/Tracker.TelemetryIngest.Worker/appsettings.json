{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "BeeTracker": {
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=beetracker;Username=beetracker;Password=beetracker"
    },
    "TrackerNode": {
      "NodeId": "telemetry-node-1",
      "Region": "dev-local"
    },
    "TelemetryBatching": {
      "BatchSize": 250,
      "FlushIntervalMilliseconds": 1000
    },
    "StartupBootstrap": {
      "MaxAttempts": 20,
      "RetryDelaySeconds": 3
    }
  }
}
