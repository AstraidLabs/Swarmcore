{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swarmcore": {
    "PublicEndpoint": {
      "BaseUrl": "https://tracker.example.com",
      "ForceHttps": true,
      "EnableHsts": false,
      "HstsMaxAgeSeconds": 31536000,
      "EnableHttpsRedirection": false,
      "BaseDomain": "example.com",
      "AnnounceBaseUrl": "",
      "ScrapeBaseUrl": "",
      "AdminBaseUrl": "",
      "ApiBaseUrl": "",
      "AllowedHosts": [],
      "AllowedSubdomains": [],
      "EnableWildcardSubdomains": false
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=swarmcore;Username=swarmcore;Password=swarmcore"
    },
    "Redis": {
      "Configuration": "localhost:6379"
    },
    "TrackerNode": {
      "NodeId": "gateway-node-1",
      "Region": "dev-local"
    },
    "TelemetryBatching": {
      "BatchSize": 250,
      "FlushIntervalMilliseconds": 1000
    },
    "PolicyCache": {
      "L1Seconds": 15,
      "L2Seconds": 120
    },
    "TrackerSecurity": {
      "AnnounceMaxQueryLength": 2048,
      "ScrapeMaxQueryLength": 4096,
      "HardMaxNumWant": 200,
      "RequireCompactResponses": true,
      "AllowPasskeyInQueryString": false,
      "AllowIPv6Peers": false,
      "MaxScrapeInfoHashes": 74
    },
    "TrackerAbuseProtection": {
      "EnableAnnouncePasskeyRateLimit": true,
      "AnnouncePerPasskeyPerSecond": 30,
      "EnableAnnounceIpRateLimit": false,
      "AnnouncePerIpPerSecond": 60,
      "EnableScrapeIpRateLimit": true,
      "ScrapePerIpPerSecond": 10
    },
    "UdpTracker": {
      "Enabled": false,
      "Port": 6969,
      "ReceiveBufferSize": 65536,
      "MaxDatagramSize": 1500,
      "ConnectionIdSweepIntervalSeconds": 30
    },
    "TrustedProxy": {
      "ForwardLimit": 1,
      "KnownProxies": [
        "127.0.0.1"
      ],
      "KnownNetworks": []
    },
    "DependencyDegradation": {
      "RequireRedisForReadiness": false,
      "RequirePostgresForReadiness": false
    },
    "StartupBootstrap": {
      "MaxAttempts": 20,
      "RetryDelaySeconds": 3
    },
    "GatewayRuntime": {
      "ShardCount": 64,
      "MaxPeersPerResponse": 80,
      "PeerTtlSeconds": 2700,
      "ExpirySweepIntervalSeconds": 30
    }
  }
}
