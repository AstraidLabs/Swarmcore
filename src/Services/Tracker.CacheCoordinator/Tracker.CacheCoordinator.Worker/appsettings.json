{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "BeeTracker": {
    "Redis": {
      "Configuration": "localhost:6379"
    },
    "TrackerNode": {
