{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BeeTracker": {
    "PublicEndpoint": {
      "BaseUrl": "https://admin.example.com",
      "ForceHttps": true,
      "BaseDomain": "example.com",
      "AdminBaseUrl": "",
      "AllowedHosts": [],
      "AllowedSubdomains": [],
      "EnableWildcardSubdomains": false
    },
    "Postgres": {
      "ConnectionString": "Host=localhost;Port=5432;Database=beetracker;Username=beetracker;Password=beetracker"
    },
    "Redis": {
      "Configuration": "localhost:6379"
    },
    "TrackerNode": {
      "NodeId": "admin-node-1",
      "Region": "dev-local"
    },
    "StartupBootstrap": {
      "MaxAttempts": 20,
      "RetryDelaySeconds": 3
    },
    "AdminIdentity": {
      "AdminApiScope": "admin_api",
      "SpaClientId": "beetracker-admin-ui",
      "SpaRedirectPath": "/oidc/callback",
      "SpaPostLogoutPath": "/",
      "SessionIdleTimeoutMinutes": 60,
      "PrivilegedReauthenticationMinutes": 15,
      "AllowPasswordGrant": false,
      "DisableTransportSecurityRequirement": true,
      "BootstrapUsers": [
        {
          "UserName": "BeeAdmin",
          "Email": "BeeAdmin@local.beetracker",
          "Password": "BeePassword123!",
          "Role": "SuperAdmin",
          "Permissions": [
            "admin.dashboard.view",
            "admin.torrents.edit",
            "admin.passkeys.manage",
            "admin.tracker_access.manage",
            "admin.bans.manage",
            "admin.maintenance.execute"
          ]
        }
      ],
      "BootstrapClients": [
        {
          "ClientId": "beetracker-admin-ui",
          "DisplayName": "BeeTracker Admin UI",
          "RequirePkce": true,
          "RedirectUris": [
            "http://localhost:81/oidc/callback"
          ],
          "PostLogoutRedirectUris": [
            "http://localhost:81/"
          ],
          "Scopes": [
            "openid",
            "profile",
            "roles",
            "admin_api"
          ]
        }
      ]
    }
  }
}
